    {
      "title": "Disk Read / Write Bytes",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (device) (rate(node_disk_read_bytes_total[5m]))",
