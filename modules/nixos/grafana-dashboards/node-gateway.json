        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "title": "CPU by Mode",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (mode) (irate(node_cpu_seconds_total{mode!=\"idle\"}[5m])) / scalar(count(count by (cpu) (node_cpu_seconds_total)))",
          "refId": "A",
          "legendFormat": "{{ mode }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 15,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      }
    },
    {
      "title": "Context Switches / sec",
      "type": "timeseries",
      "gridPos": {
