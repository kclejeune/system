        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "node_memory_MemAvailable_bytes",
          "refId": "C",
          "legendFormat": "available"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 15
          },
          "unit": "bytes"
        },
        "overrides": []
      }
    },
