          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|devtmpfs|overlay|squashfs|ramfs|efivarfs\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|devtmpfs|overlay|squashfs|ramfs|efivarfs\"}) * 100",
